{
  "name": "sound-hub",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "homepage": "https://github.com/WhXteBeXr/SoundHub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhXteBeXr/SoundHub.git"
  },
  "license": "Apache-2.0",
  "author": "WhXteBeXr",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "vite": "^8.0.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "format": "prettier --write \"src/**/*.{js,css}\" *.html",
    "format:check": "prettier --check \"src/**/*.{js,css}\" *.html",

    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",

    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",

    "check": "npm run format:check && npm run lint:css && npm run lint:js",
    "fix": "npm run format && npm run lint:css:fix && npm run lint:js:fix"
  }
}
